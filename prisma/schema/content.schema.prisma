model Page {
  id              String    @id @default(uuid())
  title           String
  slug            String    // e.g., "about-me"
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id])

  // 
  sections        Section[]
  subPages        Page[] @relation("SubPages")
  parentPage      Page?   @relation("SubPages", fields: [parentId], references: [id])
  parentId        String?

  // SEO Fields 
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String?

  @@unique([slug, projectId]) // Ensures "home" can exist on both sites
}

model Section {
  id                String      @id @default(uuid())
  type              SectionType
  sectionContent    SectionContent[]
  order             Int         @default(0)
  pageId            String
  page              Page        @relation(fields: [pageId], references: [id])
  
  // Layout Options
  containerType     ContainerType @default(FULL)
  columnLayout      ColumnLayout?
  parentId          String?
  parentSection     Section?    @relation("SubSections", fields: [parentId], references: [id])
  subSections       Section[]   @relation("SubSections")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}


enum SectionType {
    HERO
    BACKGROUND_IMAGE
    BACKGROUND_VIDEO
    LIST
    LIST_ITEM
    GRID
    GRID_ITEM
    GALLERY
    GALLERY_ITEM
    BANNER
    CONTACT
    CTA
    TESTIMONIAL
    OTHER
}

model SectionContent {
    id          String   @id @default(uuid())
    type        SectionContentType @default(TEXT)
    content     Content @relation(fields: [contentId], references: [id])
    contentId   String
    sectionId   String
    section     Section @relation(fields: [sectionId], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

enum SectionContentType {
    TEXT
    IMAGE
    VIDEO
    AUDIO
    DOCUMENT
    ARCHIVE
    OTHER
}

enum ContainerType {
    ROW
    COLUMN
    GRID
    FULL
}

enum ColumnLayout {
    ONE_THIRD_TWO_THIRDS
    TWO_THIRDS_ONE_THIRD
    HALF_HALF
    EQUAL_THIRDS
    EQUAL_QUARTERS
    FULL
    AUTO
}

model Content {
    id          String   @id @default(uuid())
    type        ContentType @default(POST)
    state       ContentState @default(DRAFT)
    visibility  ContentVisibility @default(HIDDEN)
    
    // Core metadata
    slug        String?   // URL friendly identifier
    title       String?   // Display title
    
    projectId   String
    project     Project  @relation(fields: [projectId], references: [id])
    
    versions    ContentVersion[]
    
    // Relations
    sectionContents SectionContent[]
    media           ContentMedia[]
    
    featuredMediaId String?
    featuredMedia   Media?   @relation("FeaturedMedia", fields: [featuredMediaId], references: [id])
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

enum ContentType {
    POST
    ALBUM
    TEXT
    OTHER
}

model ContentVersion {
    id          String   @id @default(uuid())
    contentId   String
    content     Content  @relation(fields: [contentId], references: [id])
    version     Int      @default(1) // Changed to Int for easier incrementing
    
    // The actual data snapshot
    title       String?
    body        Json?    // Flexible rich text structure
    excerpt     String?
    
    state       ContentState @default(DRAFT)
    visibility  ContentVisibility @default(HIDDEN)
    
    // Relations
    media       ContentVersionMedia[]
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([contentId, version])
}

model ContentVersionMedia {
    contentVersionId String
    contentVersion   ContentVersion @relation(fields: [contentVersionId], references: [id])
    mediaId          String
    media            Media @relation(fields: [mediaId], references: [id])
    order            Int @default(0)
    @@id([contentVersionId, mediaId])
}

model ContentMedia {
    id          String   @id @default(uuid())
    contentId   String
    content     Content  @relation(fields: [contentId], references: [id])
    mediaId     String
    media       Media    @relation(fields: [mediaId], references: [id])
    order       Int      @default(0)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([contentId, mediaId])
}

enum ContentState {
    DRAFT
    PUBLISHED
    ARCHIVED
}

enum ContentVisibility {
    HIDDEN
    VISIBLE
    PASSWORD_PROTECTED
}

model Media {
    id          String   @id @default(uuid())
    type        MediaType @default(IMAGE)
    owner       Client   @relation(fields: [ownerId], references: [id])
    ownerId     String
    
    // File details
    url         String
    filename    String?
    mimeType    String?
    size        Int?     // In bytes
    width       Int?     // For images/videos
    height      Int?     // For images/videos
    
    altText     String?
    caption     String?
    
    projectId   String
    project     Project  @relation(fields: [projectId], references: [id])
    
    // Relations
    contentVersions ContentVersionMedia[]
    contentMedia    ContentMedia[]
    featuredIn      Content[] @relation("FeaturedMedia")
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

enum MediaType {
    IMAGE
    VIDEO
    AUDIO
    DOCUMENT
    ARCHIVE
    OTHER
}
