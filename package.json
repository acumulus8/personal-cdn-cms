{
  "name": "personal-cdn-cms",
  "version": "1.0.0",
  "description": "CDN and backend CMS for my personal websites",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npx prisma migrate deploy && node --experimental-specifier-resolution=node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npx prisma generate",
    "connectDb": "cloud_sql_proxy tw-sites-cdn:us-central1:tw-sites-cdn --port=3306"
  },
